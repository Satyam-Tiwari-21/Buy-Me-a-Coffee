# Required for database-backed payments and supporters
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Razorpay Test Mode credentials (use rzp_test_... for development)
RAZORPAY_KEY_ID="rzp_test_replace_me"
RAZORPAY_KEY_SECRET="replace_me"
# Set this to the webhook secret created in Razorpay Dashboard → Webhooks.
RAZORPAY_WEBHOOK_SECRET="replace-with-a-unique-webhook-secret"

# Protect the /admin login. Use a long unique value in production.
ADMIN_PASSWORD="replace-with-a-long-unique-password"
ADMIN_COOKIE_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
